<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # http / www → https://sellchats.com
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\.sellchats\.com$ [NC]
  RewriteRule ^(.*)$ https://sellchats.com/$1 [L,R=301]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

Options -Indexes
